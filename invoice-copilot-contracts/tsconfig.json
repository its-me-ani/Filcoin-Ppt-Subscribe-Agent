{
  "compilerOptions": {
    "target": "es2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist",
    "ignoreDeprecations": "6.0",
    "rootDir": "./"
  },
  "include": ["scripts", "test", "hardhat.config.ts"]
}
