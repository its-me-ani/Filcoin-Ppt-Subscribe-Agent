# Co-Pilot frontend env (copy into .env and restart vite)
# ─────────────────────────────────────────────────────────

# Base URL of invoice-copilot-backend
VITE_COPILOT_BACKEND_URL=http://localhost:8787

# (Optional) Address of deployed InvoiceRegistry — only needed if the frontend
# wants to read anchor events directly. The backend handles all writes.
VITE_INVOICE_REGISTRY_ADDRESS=

# (Optional) Chain id for the registry. 11155420 = Optimism Sepolia.
VITE_REGISTRY_CHAIN_ID=11155420
