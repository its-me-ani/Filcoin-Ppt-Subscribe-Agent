# ───── Server ─────
PORT=8787
NODE_ENV=development

# ───── LLM provider ─────
# Supported: openai | anthropic | ollama | mock | gemini | lmstudio

# # To use Gemini:
# AI_PROVIDER=gemini
# AI_MODEL=gemini-2.5-pro
# AI_API_KEY=your_gemini_api_key

# To use local models via LM Studio:
AI_PROVIDER=lmstudio
AI_MODEL=nvidia/nemotron-3-nano-4b
AI_ENDPOINT=http://127.0.0.1:1234/v1
AI_API_KEY=lm-studio

# ───── Storage ─────
# Primary provider: lighthouse | pinata
STORAGE_PRIMARY=pinata
LIGHTHOUSE_API_KEY=
PINATA_JWT=
PINATA_GATEWAY=https://gateway.pinata.cloud

# ───── Chain (Optimism Sepolia or Filecoin Calibration) ─────
CHAIN_ID=314159
RPC_URL=https://api.calibration.node.glif.io/rpc/v1
INVOICE_REGISTRY_ADDRESS=
BACKEND_SIGNER_PRIVATE_KEY=

# ───── Payment rails ─────
X402_GATEWAY_URL=https://x402.example.dev
MPP_TEMPO_ENDPOINT=https://tempo.example.dev/mpp
ERC8004_AGENT_ADDRESS=
